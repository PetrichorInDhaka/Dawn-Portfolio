      </column>
      <column datatype='integer' name='[ASM]' role='measure' type='quantitative' />
      <column caption='Aircraft Type' datatype='string' name='[Aircraft_Type]' role='dimension' type='nominal' />
      <column caption='Airline Group' datatype='string' name='[Airline_Group]' role='dimension' type='nominal' />
      <column caption='Average Fare USD' datatype='real' default-format='C1033%' name='[Average_Fare_USD]' role='measure' type='quantitative' />
      <column caption='Booking Window Days' datatype='integer' name='[Booking_Window_Days]' role='measure' type='quantitative' />
      <column caption='BreakEven Load Factor' datatype='real' name='[BreakEven_Load_Factor]' role='measure' type='quantitative' />
      <column caption='Business Travel Index' datatype='real' name='[Business_Travel_Index]' role='measure' type='quantitative' />
      <column caption='Business Travel Percentage' datatype='real' name='[Business_Travel_Percentage]' role='measure' type='quantitative' />
      <column caption='Casm' datatype='real' name='[CASM]' role='measure' type='quantitative' />
      <column caption='Avg Fare per Carrier per Month' datatype='real' name='[Calculation_1105560534487040]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Carrier], [Month], [Route] : AVG([Average_Fare_USD]) }' />
      </column>
      <column caption='Market Share %' datatype='real' name='[Calculation_1105560544145409]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Market_Share] * 100' />
      </column>
      <column caption='Profit Margin' datatype='real' name='[Calculation_1105560544673794]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Estimated_Revenue_USD] - [Operating_Cost_USD]) / [Estimated_Revenue_USD]' />
      </column>
      <column caption='Average Fare' datatype='real' name='[Calculation_1203966528532480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Average_Fare_USD])' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_1203966528643073]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Estimated_Revenue_USD])' />
      </column>
      <column caption='Average Load Factor' datatype='real' name='[Calculation_1203966528724994]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Load_Factor])' />
      </column>
      <column caption='Average RASM' datatype='real' name='[Calculation_1203966528847875]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([RASM])' />
      </column>
      <column caption='Average Yield' datatype='real' name='[Calculation_1203966528897028]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Yield])' />
      </column>
      <column caption='Market Concentration Label' datatype='string' name='[Calculation_1203966528987141]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Market_HHI] &gt; 2500 THEN &quot;Highly Concentrated&quot;&#13;&#10;ELSEIF [Market_HHI] &gt; 1500 THEN &quot;Moderately Competitive&quot;&#13;&#10;ELSE &quot;Highly Competitive&quot;&#13;&#10;END' />
      </column>
      <column caption='Fare Spike Indicator' datatype='string' name='[Calculation_1203966529089542]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Fare_Spike_Flag] = &quot;Yes&quot;&#13;&#10;THEN &quot;Peak Pricing&quot;&#13;&#10;ELSE &quot;Normal Pricing&quot;&#13;&#10;END' />
      </column>
